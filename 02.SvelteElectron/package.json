{
  "name": "projectb-desktop",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "description": "ProjectB desktop app (Svelte + Electron)",
  "main": "apps/desktop/main.cjs",
  "scripts": {
    "build:contracts": "npm run -w @projectb/contracts build",
    "build:core": "npm run -w @projectb/core build",
    "build:packages": "npm run build:contracts && npm run build:core",
    "gen:manifest": "node scripts/gen-manifest.mjs",
    "dev:ui": "npm run gen:manifest && vite --config vite.config.ts",
    "dev:desktop": "npm run build:packages && node scripts/wait-for-port.cjs 5173 && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron apps/desktop/main.cjs",
    "dev": "concurrently -k \"npm:dev:ui\" \"npm:dev:desktop\"",
    "build:ui": "npm run gen:manifest && vite build --config vite.config.ts",
    "prebuild:masterdb": "npm rebuild better-sqlite3",
    "build:masterdb": "node scripts/generate_master_db.cjs",
    "postbuild:masterdb": "electron-rebuild -f -w better-sqlite3",
    "build": "npm run build:masterdb && npm run build:packages && npm run build:ui",
    "preview:ui": "vite preview --config vite.config.ts",
    "start": "electron apps/desktop/main.cjs",
    "pack": "npm run build && electron-builder --dir",
    "check:i18n:keys": "node scripts/check-i18n-keys.mjs",
    "check:mojibake": "node scripts/check-mojibake.mjs",
    "check:encoding": "npm run check:mojibake",
    "gen:npc": "node scripts/generate-npc-people.mjs",
    "deploy": "node scripts/deploy-staging.mjs",
    "migrate:entities": "node scripts/migrate-entities.mjs",
    "migrate:append:jbl": "node scripts/migrate-entities.mjs -- --append people_jbl.json",
    "audit": "npm audit --audit-level=high",
    "postinstall": "electron-rebuild -f -w better-sqlite3"
  },
  "build": {
    "appId": "com.projectb.desktop",
    "productName": "ProjectB",
    "directories": {
      "output": "release"
    },
    "files": [
      "apps/desktop/**",
      "dist/ui/**",
      "packages/*/dist/**",
      "resource/**",
      "!resource/data/staging/**",
      "!scripts/**",
      "!docs/**"
    ],
    "asarUnpack": [
      "resource/**",
      "packages/*/dist/**"
    ],
    "win": {
      "target": [
        {
          "target": "dir"
        }
      ]
    },
    "npmRebuild": true
  },
  "dependencies": {
    "better-sqlite3": "^12.10.0",
    "svelte": "^5.38.7"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "@sveltejs/vite-plugin-svelte": "^5.1.1",
    "@types/node": "^22.15.21",
    "concurrently": "^9.2.0",
    "cross-env": "^7.0.3",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "typescript": "^5.8.3",
    "vite": "^6.2.2"
  }
}
