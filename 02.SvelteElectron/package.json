{
  "name": "projectb-desktop",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "description": "ProjectB desktop app (Svelte + Electron)",
  "main": "apps/desktop/main.cjs",
  "scripts": {
    "build:contracts": "npm run -w @projectb/contracts build",
    "build:core": "npm run -w @projectb/core build",
    "build:native": "npm run -w @projectb/engine-native build",
    "build:packages": "npm run build:contracts && npm run build:core",
    "gen:manifest": "node scripts/gen-manifest.mjs",
    "gen:contacts": "node scripts/gen-manifest.mjs --force",
    "gen:index": "node scripts/rebuild_entity_index.cjs",
    "dev:ui": "npm run gen:manifest && vite --config vite.config.ts",
    "dev:desktop": "npm run build:masterdb && npm run build:packages && node scripts/wait-for-port.cjs 5173 && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron apps/desktop/main.cjs",
    "predev": "npm run build:native || echo [engine-native] Rust 빌드 실패 - match engine stubs 사용 (dev 전용)",
    "dev": "concurrently -k \"npm:dev:ui\" \"npm:dev:desktop\"",
    "build:ui": "npm run gen:manifest && vite build --config vite.config.ts",
    "build:masterdb": "electron scripts/generate_master_db.cjs",
    "prebuild": "npm run build:native",
    "build": "npm run build:masterdb && npm run build:packages && npm run build:ui",
    "predeploy": "npm run build",
    "preview:ui": "vite preview --config vite.config.ts",
    "start": "electron apps/desktop/main.cjs",
    "pack": "npm run build && cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --dir",
    "check:i18n:keys": "node scripts/check-i18n-keys.mjs",
    "check:mojibake": "node scripts/check-mojibake.mjs",
    "check:encoding": "npm run check:mojibake",
    "gen:npc": "node scripts/generate-npc-people.mjs",
    "deploy": "node scripts/deploy-staging.mjs",
    "migrate:entities": "node scripts/migrate-entities.mjs",
    "migrate:append:jbl": "node scripts/migrate-entities.mjs -- --append people_jbl.json",
    "test": "vitest run --config vitest.config.ts",
    "test:watch": "vitest --config vitest.config.ts",
    "test:db": "electron scripts/db-perf.mjs",
    "smoke": "node scripts/smoke-test.mjs",
    "audit": "npm audit --audit-level=high",
    "postinstall": "electron-rebuild -f -w better-sqlite3",
    "test:slotdb": "cross-env ELECTRON_RUN_AS_NODE=1 electron scripts/test-slotdb.cjs",
    "test:rostergen": "cross-env ELECTRON_RUN_AS_NODE=1 electron scripts/test-roster-gen.cjs",
    "test:newgame": "cross-env ELECTRON_RUN_AS_NODE=1 electron scripts/test-newgame-v3.cjs",
    "test:v3": "npm run test:slotdb && npm run test:rostergen && npm run test:newgame && npm run test:draftpool",
    "test:draftpool": "cross-env ELECTRON_RUN_AS_NODE=1 electron scripts/test-draft-pool.cjs"
  },
  "build": {
    "appId": "com.projectb.desktop",
    "productName": "ProjectB",
    "directories": {
      "output": "release"
    },
    "files": [
      "apps/desktop/**",
      "dist/ui/**",
      "packages/*/dist/**",
      "packages/*/package.json",
      "packages/engine-native/index.js",
      "packages/engine-native/*.node",
      "resource/**",
      "!resource/data/staging/**",
      "!resource/data/balance/**",
      "!resource/data/master/entities/players/**",
      "!scripts/**",
      "!docs/**"
    ],
    "asarUnpack": [
      "resource/**",
      "packages/*/dist/**",
      "packages/*/package.json",
      "packages/engine-native/**"
    ],
    "win": {
      "target": [
        {
          "target": "dir"
        }
      ]
    },
    "npmRebuild": true
  },
  "dependencies": {
    "better-sqlite3": "^12.10.0",
    "svelte": "^5.38.7"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "@sveltejs/vite-plugin-svelte": "^5.1.1",
    "@types/node": "^22.15.21",
    "concurrently": "^9.2.0",
    "cross-env": "^7.0.3",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "typescript": "^5.8.3",
    "vite": "^6.2.2",
    "vitest": "^3.2.6"
  }
}
