# 모든 텍스트 파일 LF로 통일
* text=auto eol=lf

# 명시적 텍스트 파일
*.ts        text eol=lf
*.svelte    text eol=lf
*.js        text eol=lf
*.cjs       text eol=lf
*.mjs       text eol=lf
*.json      text eol=lf
*.toml      text eol=lf
*.rs        text eol=lf
*.md        text eol=lf
*.html      text eol=lf
*.css       text eol=lf
*.sql       text eol=lf
*.sh        text eol=lf

# 바이너리 파일 (변환 금지)
*.node      binary
*.db        binary
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.ico       binary
*.woff      binary
*.woff2     binary
*.ttf       binary
*.otf       binary
*.eot       binary
