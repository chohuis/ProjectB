{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "types": ["vite/client"],
    "skipLibCheck": true,
    "paths": {
      "@core/*": ["./packages/core/src/*"]
    }
  },
  "include": [
    "apps/ui/src/**/*.ts",
    "apps/ui/src/**/*.d.ts",
    "packages/core/src/**/*.ts"
  ]
}

