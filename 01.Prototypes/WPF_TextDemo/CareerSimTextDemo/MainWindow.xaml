<Window x:Class="CareerSimTextDemo.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Career Sim Text Prototype" Height="900" Width="1400"
        Background="#0E1017" Foreground="#F5F5F5">
    <Grid x:Name="RootGrid">
        <Grid x:Name="MainLayout" Margin="18">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" Padding="18" CornerRadius="8" Background="#1B1F2D">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Width="420">
                        <TextBlock Text="Career Baseball Life - Text Demo" FontSize="24" FontWeight="Bold"/>
                        <TextBlock x:Name="PlayerSummaryText" Margin="0,8,0,0"/>
                        <TextBlock x:Name="PitchInfoText" Margin="0,4,0,0"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <TextBlock Text="현재 진행일" HorizontalAlignment="Right"/>
                        <TextBlock x:Name="CurrentDayText" FontSize="20" FontWeight="Bold" HorizontalAlignment="Right"/>
                        <Button x:Name="AdvanceButton" Content="진행" Width="160" Margin="0,10,0,0" HorizontalAlignment="Right" Click="AdvanceButton_OnClick"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Main Content -->
            <Grid Grid.Row="1" Margin="0,16,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="220"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Main Menu -->
                <Border Padding="14" CornerRadius="8" Background="#1B1F2D">
                    <StackPanel>
                        <TextBlock Text="메인 메뉴" FontSize="16" FontWeight="Bold"/>
                        <ListBox x:Name="SectionList" SelectionChanged="SectionList_OnSelectionChanged"
                                 Background="Transparent" BorderThickness="0" Margin="0,8,0,0">
                            <ListBox.Resources>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Padding" Value="0"/>
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListBoxItem">
                                                <Border x:Name="Root" Background="#252A3B" CornerRadius="6" Margin="0,4,0,4">
                                                    <ContentPresenter Margin="12,8"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsSelected" Value="True">
                                                        <Setter TargetName="Root" Property="Background" Value="#3B4A6D"/>
                                                    </Trigger>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Root" Property="Background" Value="#30384F"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListBox.Resources>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Title}" FontSize="14" FontWeight="Bold" Margin="4,0"/>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </StackPanel>
                </Border>

                <!-- Detail Panels -->
                <Grid Grid.Column="1" Margin="16,0,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Home Panel -->
                    <Grid x:Name="HomePanel" Grid.Row="0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Border Padding="16" CornerRadius="8" Background="#1B1F2D">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="선수 프로필" FontSize="18" FontWeight="Bold"/>
                                    <TextBlock x:Name="InfoSchoolText" Margin="0,6,0,0" FontSize="14"/>
                                    <TextBlock x:Name="InfoPitchStyleText" FontSize="12" Margin="0,2,0,0"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="구종 구성" FontWeight="Bold"/>
                                    <ItemsControl x:Name="PitchList" Margin="0,4,0,0">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="•" Margin="0,0,4,0"/>
                                                    <TextBlock Text="{Binding}"/>
                                                </StackPanel>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Border Grid.Row="1" Margin="0,12,0,0" Padding="16" CornerRadius="8" Background="#1B1F2D">
                            <StackPanel>
                                <TextBlock Text="학년 · 시즌 진행" FontSize="16" FontWeight="Bold"/>
                                <WrapPanel Margin="0,8,0,0" ItemWidth="220">
                                    <StackPanel Margin="0,0,16,8">
                                        <TextBlock Text="학년" FontWeight="Bold"/>
                                        <TextBlock x:Name="LoopAcademicYearText" FontSize="14"/>
                                    </StackPanel>
                                    <StackPanel Margin="0,0,16,8">
                                        <TextBlock Text="현재 날짜" FontWeight="Bold"/>
                                        <TextBlock x:Name="LoopCalendarText" FontSize="14"/>
                                    </StackPanel>
                                    <StackPanel Margin="0,0,16,8">
                                        <TextBlock Text="주차" FontWeight="Bold"/>
                                        <TextBlock x:Name="LoopWeekText" FontSize="14"/>
                                    </StackPanel>
                                    <StackPanel Margin="0,0,16,8">
                                        <TextBlock Text="시즌 단계" FontWeight="Bold"/>
                                        <TextBlock x:Name="LoopPhaseText" FontSize="14"/>
                                    </StackPanel>
                                    <StackPanel Margin="0,0,16,8">
                                        <TextBlock Text="멘탈/분위기" FontWeight="Bold"/>
                                        <TextBlock x:Name="LoopMoodText" FontSize="14"/>
                                    </StackPanel>
                                    <StackPanel Margin="0,0,16,8">
                                        <TextBlock Text="훈련/피로" FontWeight="Bold"/>
                                        <TextBlock x:Name="LoopTrainingText" FontSize="14"/>
                                    </StackPanel>
                                </WrapPanel>
                                <StackPanel Margin="0,8,0,0">
                                    <TextBlock Text="다가오는 이벤트" FontWeight="Bold"/>
                                    <TextBlock x:Name="LoopUpcomingText" FontSize="14" TextWrapping="Wrap"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <Grid Grid.Row="2" Margin="0,12,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Padding="16" Background="#1B1F2D" CornerRadius="8" Margin="0,0,12,0">
                                <StackPanel>
                                    <TextBlock Text="최근 5경기 기록" FontSize="16" FontWeight="Bold"/>
                                    <ItemsControl x:Name="RecentMatchList" Margin="0,10,0,0">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="#23293C" CornerRadius="4" Padding="8" Margin="0,0,0,6">
                                                    <TextBlock Text="{Binding}" TextWrapping="Wrap"/>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="1" Padding="16" Background="#1B1F2D" CornerRadius="8">
                                <StackPanel>
                                    <TextBlock Text="다가올 주요 이벤트" FontSize="16" FontWeight="Bold"/>
                                    <TextBlock Text="루프 데이터와 동일한 타임라인을 요약합니다." Margin="0,6,0,0" Foreground="#9099B5"/>
                                    <ItemsControl x:Name="HomeUpcomingList" Margin="0,10,0,0">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="#23293C" CornerRadius="4" Padding="8" Margin="0,0,0,6">
                                                    <StackPanel>
                                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
                                                            <TextBlock Text="{Binding CountdownLabel}" Width="60" Foreground="#FFD66E" FontWeight="Bold"/>
                                                            <TextBlock Text="{Binding Label}" Width="80" Foreground="#C9CEDD"/>
                                                            <TextBlock Text="{Binding Summary}" Margin="8,0,0,0"/>
                                                        </StackPanel>
                                                        <TextBlock Text="{Binding Preview}" FontSize="11" Foreground="#A5B1CA" TextWrapping="Wrap"/>
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Grid>

                    <!-- Info Panel -->
                    <Grid x:Name="InfoPanel" Grid.Row="0" Visibility="Collapsed">
                        <Border Padding="16" CornerRadius="8" Background="#1B1F2D">
                            <StackPanel>
                                <TextBlock Text="신체 · 기술 · 멘탈 능력치" FontSize="16" FontWeight="Bold"/>
                                <Grid Margin="0,12,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <Border Padding="12" Background="#20273A" CornerRadius="8" Margin="0,0,12,0">
                                        <StackPanel>
                                            <TextBlock Text="신체 능력치" FontWeight="Bold" FontSize="14"/>
                                            <ListView x:Name="PhysicalStatsList" Margin="0,8,0,0" Background="#20273A" BorderThickness="0" Foreground="#F5F5F5">
                                                <ListView.View>
                                                    <GridView>
                                                        <GridViewColumn Header="항목" DisplayMemberBinding="{Binding Label}" Width="180"/>
                                                        <GridViewColumn Header="값" Width="70">
                                                            <GridViewColumn.CellTemplate>
                                                                <DataTemplate>
                                                                    <TextBlock Text="{Binding Value, StringFormat=F1}" HorizontalAlignment="Right"/>
                                                                </DataTemplate>
                                                            </GridViewColumn.CellTemplate>
                                                        </GridViewColumn>
                                                    </GridView>
                                                </ListView.View>
                                            </ListView>
                                        </StackPanel>
                                    </Border>

                                    <Border Grid.Column="1" Padding="12" Background="#20273A" CornerRadius="8" Margin="0,0,12,0">
                                        <StackPanel>
                                            <TextBlock Text="기술 능력치" FontWeight="Bold" FontSize="14"/>
                                            <ListView x:Name="TechnicalStatsList" Margin="0,8,0,0" Background="#20273A" BorderThickness="0" Foreground="#F5F5F5">
                                                <ListView.View>
                                                    <GridView>
                                                        <GridViewColumn Header="항목" DisplayMemberBinding="{Binding Label}" Width="200"/>
                                                        <GridViewColumn Header="값" Width="70">
                                                            <GridViewColumn.CellTemplate>
                                                                <DataTemplate>
                                                                    <TextBlock Text="{Binding Value, StringFormat=F1}" HorizontalAlignment="Right"/>
                                                                </DataTemplate>
                                                            </GridViewColumn.CellTemplate>
                                                        </GridViewColumn>
                                                    </GridView>
                                                </ListView.View>
                                            </ListView>
                                        </StackPanel>
                                    </Border>

                                    <Border Grid.Column="2" Padding="12" Background="#20273A" CornerRadius="8">
                                        <StackPanel>
                                            <TextBlock Text="멘탈/기타" FontWeight="Bold" FontSize="14"/>
                                            <ListView x:Name="MentalStatsList" Margin="0,8,0,0" Background="#20273A" BorderThickness="0" Foreground="#F5F5F5">
                                                <ListView.View>
                                                    <GridView>
                                                        <GridViewColumn Header="항목" DisplayMemberBinding="{Binding Label}" Width="200"/>
                                                        <GridViewColumn Header="값" Width="70">
                                                            <GridViewColumn.CellTemplate>
                                                                <DataTemplate>
                                                                    <TextBlock Text="{Binding Value, StringFormat=F1}" HorizontalAlignment="Right"/>
                                                                </DataTemplate>
                                                            </GridViewColumn.CellTemplate>
                                                        </GridViewColumn>
                                                    </GridView>
                                                </ListView.View>
                                            </ListView>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                                <Border Margin="0,16,0,0" Padding="12" Background="#20273A" CornerRadius="8">
                                    <StackPanel>
                                        <TextBlock Text="다가올 일정 타임라인" FontSize="16" FontWeight="Bold"/>
                                        <ItemsControl x:Name="InfoLoopList" Margin="0,10,0,0">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <StackPanel Margin="0,2,0,6">
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Text="{Binding Label}" Width="80" Foreground="#C9CEDD"/>
                                                            <TextBlock Text="{Binding CountdownLabel}" Width="70" Foreground="#FFD66E"/>
                                                            <TextBlock Text="{Binding Summary}" Margin="8,0,0,0"/>
                                                        </StackPanel>
                                                        <TextBlock Text="{Binding Preview}" FontSize="11" Foreground="#98A2C1" TextWrapping="Wrap"/>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- Roster Panel -->
                    <Grid x:Name="RosterPanel" Grid.Row="0" Visibility="Collapsed">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Border Padding="16" CornerRadius="8" Background="#1B1F2D">
                            <StackPanel>
                                <TextBlock Text="감독 &amp; 코치진" FontSize="16" FontWeight="Bold"/>
                                <ItemsControl x:Name="RosterStaffList" Margin="0,8,0,0">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" Margin="0,2,0,2">
                                                <TextBlock Text="{Binding Role}" Width="90" FontWeight="Bold"/>
                                                <TextBlock Text="{Binding Name}" Width="120"/>
                                                <TextBlock Text="{Binding Specialty}" Width="110" Foreground="#C0C6D9"/>
                                                <TextBlock Text="{Binding RatingSummary}" Foreground="#8EA0C9"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <TextBlock Text="주장/부주장 및 라이벌 이벤트는 추후 업데이트 예정입니다." FontSize="12" Foreground="#C0C6D9" Margin="0,8,0,0" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                        <Grid Grid.Row="1" Margin="0,12,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width="3*"/>
                            </Grid.ColumnDefinitions>
                            <Border Padding="14" Background="#1B1F2D" CornerRadius="8" Margin="0,0,12,0">
                                <StackPanel>
                                    <TextBlock Text="야구부 선수단" FontSize="16" FontWeight="Bold"/>
                                    <ListView x:Name="RosterList" Margin="0,10,0,0" Height="360" Background="#1B1F2D" BorderThickness="0" Foreground="#F5F5F5"
                                              SelectionChanged="RosterList_OnSelectionChanged"
                                              MouseDoubleClick="RosterList_OnMouseDoubleClick">
                                        <ListView.View>
                                            <GridView>
                                                <GridViewColumn Header="이름" DisplayMemberBinding="{Binding Name}" Width="130"/>
                                                <GridViewColumn Header="포지션/역할" DisplayMemberBinding="{Binding Role}" Width="180"/>
                                                <GridViewColumn Header="학년/상태" DisplayMemberBinding="{Binding StatusLabel}" Width="120"/>
                                                <GridViewColumn Header="태그" DisplayMemberBinding="{Binding Tags}" Width="140"/>
                                            </GridView>
                                        </ListView.View>
                                    </ListView>
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="1" Padding="16" Background="#1B1F2D" CornerRadius="8">
                                <StackPanel>
                                    <TextBlock Text="상세 정보" FontSize="16" FontWeight="Bold"/>
                                    <TextBlock x:Name="RosterDetailNameText" FontSize="22" FontWeight="Bold" Margin="0,6,0,0"/>
                                    <TextBlock x:Name="RosterDetailMetaText" FontSize="13" Foreground="#C0C6D9" Margin="0,2,0,0"/>
                                    <TextBlock x:Name="RosterDetailArchetypeText" FontSize="13" Margin="0,2,0,0"/>
                                    <TextBlock x:Name="RosterDetailTagsText" FontSize="12" Foreground="#E0B973" Margin="0,2,0,0"/>
                                    <TextBlock x:Name="RosterDetailOverallText" FontSize="13" Margin="0,6,0,0"/>
                                    <TextBlock x:Name="RosterDetailPlaceholder" Text="선수를 선택하면 상세 능력치가 표시됩니다." Margin="0,20,0,0" Foreground="#7C8299"/>
                                    <Grid Margin="0,12,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="신체" FontWeight="Bold"/>
                                            <ItemsControl x:Name="RosterPhysicalList" Margin="0,4,0,0">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <DockPanel>
                                                            <TextBlock Text="{Binding Label}" Width="100"/>
                                                            <TextBlock Text="{Binding Value}" HorizontalAlignment="Right"/>
                                                        </DockPanel>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Margin="12,0,0,0">
                                            <TextBlock Text="투구" FontWeight="Bold"/>
                                            <ItemsControl x:Name="RosterPitchingList" Margin="0,4,0,0">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <DockPanel>
                                                            <TextBlock Text="{Binding Label}" Width="120"/>
                                                            <TextBlock Text="{Binding Value}" HorizontalAlignment="Right"/>
                                                        </DockPanel>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                        <StackPanel Grid.Column="2" Margin="12,0,0,0">
                                            <TextBlock Text="타격/수비" FontWeight="Bold"/>
                                            <ItemsControl x:Name="RosterBattingList" Margin="0,4,0,0">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <DockPanel>
                                                            <TextBlock Text="{Binding Label}" Width="130"/>
                                                            <TextBlock Text="{Binding Value}" HorizontalAlignment="Right"/>
                                                        </DockPanel>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </Grid>
                                    <Grid Margin="0,12,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="멘탈" FontWeight="Bold"/>
                                            <ItemsControl x:Name="RosterMentalList" Margin="0,4,0,0">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <DockPanel>
                                                            <TextBlock Text="{Binding Label}" Width="100"/>
                                                            <TextBlock Text="{Binding Value}" HorizontalAlignment="Right"/>
                                                        </DockPanel>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Margin="12,0,0,0">
                                            <TextBlock Text="숨은/성향" FontWeight="Bold"/>
                                            <ItemsControl x:Name="RosterHiddenList" Margin="0,4,0,0">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <DockPanel>
                                                            <TextBlock Text="{Binding Label}" Width="130"/>
                                                            <TextBlock Text="{Binding Value}" HorizontalAlignment="Right"/>
                                                        </DockPanel>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Grid>

                    <!-- Training Panel -->
                    <Grid x:Name="TrainingPanel" Grid.Row="0" Visibility="Collapsed">
                        <Border Padding="14" CornerRadius="8" Background="#1B1F2D">
                            <StackPanel>
                                <TextBlock Text="훈련 세션 설정" FontSize="16" FontWeight="Bold"/>
                                <TextBlock Text="Morning / Afternoon / Evening 행동을 조합해 세션으로 저장합니다." FontSize="12" Margin="0,4,0,12"/>
                                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                    <TextBlock Text="아침" Width="100" VerticalAlignment="Center"/>
                                    <ComboBox x:Name="MorningActionCombo" DisplayMemberPath="Name" Width="300" SelectionChanged="MorningActionCombo_OnSelectionChanged"/>
                                </StackPanel>
                                <TextBlock Text="설명" FontSize="11" Margin="100,2,0,0"/>
                                <TextBlock x:Name="MorningDescription" Margin="100,0,0,8" FontSize="11" TextWrapping="Wrap"/>

                                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                    <TextBlock Text="점심" Width="100" VerticalAlignment="Center"/>
                                    <ComboBox x:Name="AfternoonActionCombo" DisplayMemberPath="Name" Width="300" SelectionChanged="AfternoonActionCombo_OnSelectionChanged"/>
                                </StackPanel>
                                <TextBlock Text="설명" FontSize="11" Margin="100,2,0,0"/>
                                <TextBlock x:Name="AfternoonDescription" Margin="100,0,0,8" FontSize="11" TextWrapping="Wrap"/>

                                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                    <TextBlock Text="저녁" Width="100" VerticalAlignment="Center"/>
                                    <ComboBox x:Name="EveningActionCombo" DisplayMemberPath="Name" Width="300" SelectionChanged="EveningActionCombo_OnSelectionChanged"/>
                                </StackPanel>
                                <TextBlock Text="설명" FontSize="11" Margin="100,2,0,0"/>
                                <TextBlock x:Name="EveningDescription" Margin="100,0,0,8" FontSize="11" TextWrapping="Wrap"/>

                                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                    <TextBlock Text="세션 이름" Width="100" VerticalAlignment="Center"/>
                                    <TextBox x:Name="SessionNameText" Width="200" Margin="0,0,12,0"/>
                                    <Button x:Name="AddSessionButton" Content="훈련 세션 등록" Width="140" Click="AddSessionButton_OnClick"/>
                                </StackPanel>
                                <ListBox x:Name="TrainingSessionList" Margin="0,8,0,0" Height="120" DisplayMemberPath="DisplayText"/>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                    <Button x:Name="RemoveSessionButton" Content="선택 삭제" Width="110" Margin="0,8,8,0" Click="RemoveSessionButton_OnClick"/>
                                    <Button x:Name="AdvanceTrainingButton" Content="하루 진행" Width="150" Margin="0,8,0,0" Click="AdvanceButton_OnClick"/>
                                </StackPanel>

                                <TextBlock Text="주차별 훈련 계획" FontSize="14" FontWeight="Bold" Margin="0,12,0,4"/>
                                <ListView x:Name="WeeklyPlanList" Height="120" Margin="0,0,0,8">
                                    <ListView.View>
                                        <GridView>
                                            <GridViewColumn Header="주차" DisplayMemberBinding="{Binding WeekLabel}" Width="70"/>
                                            <GridViewColumn Header="아침" DisplayMemberBinding="{Binding Morning}" Width="140"/>
                                            <GridViewColumn Header="점심" DisplayMemberBinding="{Binding Afternoon}" Width="140"/>
                                            <GridViewColumn Header="저녁" DisplayMemberBinding="{Binding Evening}" Width="140"/>
                                            <GridViewColumn Header="세션" DisplayMemberBinding="{Binding SessionName}" Width="140"/>
                                        </GridView>
                                    </ListView.View>
                                </ListView>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                    <ComboBox x:Name="WeeklyPlanWeekCombo" Width="140" DisplayMemberPath="WeekLabel"/>
                                    <ComboBox x:Name="WeeklyPlanSessionCombo" Width="200" Margin="8,0,0,0" DisplayMemberPath="Name"/>
                                    <Button Content="세션 적용" Width="130" Margin="8,0,0,0" Click="ApplyWeeklyPlanButton_OnClick"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </Grid>

                     <!-- Schedule Panel -->
                     <Grid x:Name="SchedulePanel" Grid.Row="0" Visibility="Collapsed">
                         <Border Padding="16" CornerRadius="8" Background="#1B1F2D">
                             <StackPanel>
                                 <TextBlock Text="1학년 일정" FontSize="18" FontWeight="Bold"/>
                                <TabControl Margin="0,8,0,0">
                                    <TabItem Header="전체 목록">
                                        <ListView x:Name="ScheduleList" Margin="0,8,0,0">
                                            <ListView.View>
                                                <GridView>
                                                    <GridViewColumn Header="날짜" DisplayMemberBinding="{Binding DateLabel}" Width="140"/>
                                                    <GridViewColumn Header="카테고리" DisplayMemberBinding="{Binding Category}" Width="100"/>
                                                    <GridViewColumn Header="이벤트" DisplayMemberBinding="{Binding Title}" Width="220"/>
                                                    <GridViewColumn Header="설명" DisplayMemberBinding="{Binding Description}" Width="380"/>
                                                </GridView>
                                            </ListView.View>
                                        </ListView>
                                    </TabItem>
                                    <TabItem Header="월별 보기">
                                        <StackPanel>
                                            <ComboBox x:Name="CalendarMonthCombo" Width="200" DisplayMemberPath="Name" Margin="0,0,0,8" SelectionChanged="CalendarMonthCombo_OnSelectionChanged"/>
                                            <ItemsControl x:Name="CalendarDayGrid">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <UniformGrid Columns="7" Rows="6"/>
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border BorderBrush="#2E3448" BorderThickness="1" Padding="6" MinHeight="80">
                                                            <StackPanel>
                                                                <TextBlock Text="{Binding DayText}" FontWeight="Bold"/>
                                                                <ItemsControl ItemsSource="{Binding Events}">
                                                                    <ItemsControl.ItemTemplate>
                                                                        <DataTemplate>
                                                                            <TextBlock FontSize="10" TextWrapping="Wrap">
                                                                                <Run Text="• "/>
                                                                                <Run Text="{Binding Mode=OneWay}"/>
                                                                            </TextBlock>
                                                                        </DataTemplate>
                                                                    </ItemsControl.ItemTemplate>
                                                                </ItemsControl>
                                                            </StackPanel>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </TabItem>
                                 </TabControl>
                             </StackPanel>
                         </Border>
                     </Grid>

                    <!-- Records Panel -->
                    <Grid x:Name="RecordsPanel" Grid.Row="0" Visibility="Collapsed">
                        <Border Padding="16" CornerRadius="8" Background="#1B1F2D">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <StackPanel Grid.Row="0" Margin="0,0,0,12">
                                    <TextBlock Text="기록 · 로그 아카이브" FontSize="18" FontWeight="Bold"/>
                                    <TextBlock Text="하루 진행 로그와 이벤트를 일자별로 정리해서 확인합니다." FontSize="12" Foreground="#9FA9C4" Margin="0,4,0,0"/>
                                </StackPanel>
                                <ListBox x:Name="LogBlockList"
                                         Grid.Row="1"
                                         Background="#1B1F2D"
                                         BorderThickness="0"
                                         ScrollViewer.VerticalScrollBarVisibility="Auto">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Expander Header="{Binding Title}"
                                                      IsExpanded="True"
                                                      Background="#23293C"
                                                      Foreground="#F5F5F5"
                                                      Margin="0,0,0,8">
                                                <ItemsControl ItemsSource="{Binding Entries}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Border Background="#1E2434" CornerRadius="4" Padding="6" Margin="0,2,0,2">
                                                                <TextBlock Text="{Binding}" TextWrapping="Wrap" Foreground="#FFFFFF"/>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </Expander>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Grid>
                        </Border>
                    </Grid>

                    <!-- Match Panel -->
                    <!-- Log Area -->
                </Grid>
            </Grid>
        </Grid>

         <!-- School Selection Overlay -->
         <Grid x:Name="SchoolSelectionOverlay" Background="#BF000000">
             <Border Padding="28" Background="#151824" CornerRadius="12" Width="1380" Height="760" HorizontalAlignment="Center" VerticalAlignment="Center">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="5*"/>
                        <ColumnDefinition Width="4*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="입학할 고등학교를 선택하세요" FontSize="20" FontWeight="Bold"/>
                        <TextBlock Text="좌측 리스트에서 학교를 고른 뒤 [입학 확정] 버튼을 누르면 1학년 시즌이 시작됩니다." FontSize="12" Margin="0,4,0,12"/>
                        <ListBox x:Name="SchoolListBox" Height="600" Background="Transparent" BorderThickness="0" SelectionChanged="SchoolListBox_OnSelectionChanged"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                            <ListBox.Resources>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Padding" Value="0"/>
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListBoxItem">
                                                <Border x:Name="OverlayItem" Background="#1F273A" CornerRadius="6" Margin="0,4,0,4">
                                                    <ContentPresenter Margin="12"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsSelected" Value="True">
                                                        <Setter TargetName="OverlayItem" Property="Background" Value="#2F3D59"/>
                                                    </Trigger>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="OverlayItem" Property="Background" Value="#25304A"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListBox.Resources>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="140"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="{Binding Name}" FontSize="16" FontWeight="Bold"/>
                                            <TextBlock Text="{Binding RegionTierLine}" FontSize="12" Foreground="#C9CEDD"/>
                                            <TextBlock Text="{Binding Keywords}" FontSize="11" Foreground="#9FA9C4"/>
                                            <TextBlock Text="{Binding TopPlayerSummary}" FontSize="11" Foreground="#ADB7CE" TextWrapping="Wrap" Margin="0,6,0,0"/>
                                            <TextBlock Text="{Binding LoopPreviewSummary}" FontSize="11" Foreground="#8FA1C4" TextWrapping="Wrap" Margin="0,2,0,0"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                                            <TextBlock Text="{Binding AvgOverallText}" FontSize="20" FontWeight="Bold" HorizontalAlignment="Right"/>
                                            <TextBlock Text="평균 OVR" FontSize="11" Foreground="#9FA9C4" HorizontalAlignment="Right"/>
                                            <TextBlock Text="{Binding StrengthLabel}" FontSize="12" Foreground="#F8D57E" HorizontalAlignment="Right" Margin="0,6,0,0"/>
                                            <TextBlock Text="{Binding RosterCountLine}" FontSize="11" Foreground="#C9CEDD" HorizontalAlignment="Right" Margin="0,4,0,0"/>
                                        </StackPanel>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </StackPanel>
                    <Border Grid.Column="1" Background="#1F273A" CornerRadius="8" Padding="16" Margin="16,0,0,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
                                <StackPanel>
                                    <TextBlock Text="학교 정보" FontSize="18" FontWeight="Bold"/>
                                    <TextBlock x:Name="SelectedSchoolName" FontSize="22" FontWeight="Bold" Margin="0,8,0,0"/>
                                    <TextBlock x:Name="SelectedSchoolRegion" Margin="0,2,0,0"/>
                                    <TextBlock x:Name="SelectedSchoolKeywords" FontSize="12" Foreground="#B0BCD6" Margin="0,2,0,0"/>
                                    <TextBlock x:Name="SelectedSchoolStrength" FontSize="12" Foreground="#F8D57E" Margin="0,4,0,0"/>
                                    <Separator Margin="0,12,0,12" Background="#2A3147" Height="1"/>
                                    <TextBlock Text="철학" FontWeight="Bold" Margin="0,16,0,0"/>
                                    <TextBlock x:Name="SelectedSchoolPhilosophy" TextWrapping="Wrap"/>
                                    <TextBlock Text="운영 지표" FontWeight="Bold" Margin="0,16,0,0"/>
                                    <TextBlock x:Name="SelectedSchoolStats" TextWrapping="Wrap"/>
                                    <TextBlock Text="로스터 요약" FontWeight="Bold" Margin="0,16,0,0"/>
                                    <TextBlock x:Name="SelectedSchoolRosterStats" TextWrapping="Wrap"/>
                                    <TextBlock x:Name="SelectedSchoolTopPlayerSummary" FontSize="12" Foreground="#A5B1CA" Margin="0,6,0,0" TextWrapping="Wrap"/>
                                    <ItemsControl x:Name="SelectedSchoolTopPlayersList" Margin="0,8,0,0">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="#242E45" CornerRadius="4" Padding="8" Margin="0,2,0,2">
                                                    <StackPanel>
                                                        <TextBlock Text="{Binding ListLabel}" FontWeight="SemiBold"/>
                                                        <TextBlock Text="{Binding DetailLine}" FontSize="11" Foreground="#C9CEDD" Margin="0,2,0,0"/>
                                                        <TextBlock Text="{Binding TagsText}" FontSize="11" Foreground="#7985A4"/>
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                    <TextBlock Text="1학년 루프 프리뷰" FontWeight="Bold" Margin="0,16,0,0"/>
                                    <TextBlock x:Name="SelectedSchoolLoopSummary" FontSize="12" Foreground="#A5B1CA" TextWrapping="Wrap"/>
                                    <ItemsControl x:Name="SelectedSchoolLoopPreviewList" Margin="0,6,0,0">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal" Margin="0,2,0,2">
                                                    <TextBlock Text="{Binding Label}" Width="90" Foreground="#C9CEDD"/>
                                                    <TextBlock Text="{Binding Summary}" Foreground="#F5F5F5" TextWrapping="Wrap"/>
                                                </StackPanel>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </ScrollViewer>
                            <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                                <Button Content="입학 확정" Width="160" Click="ConfirmSchoolButton_OnClick"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
             </Border>
         </Grid>

        <!-- Daily Log Overlay -->
        <Grid x:Name="DailyLogOverlay" Background="#BF000000" Visibility="Collapsed">
            <Border Padding="28" Background="#151B2B" CornerRadius="12" Width="780" Height="540" HorizontalAlignment="Center" VerticalAlignment="Center">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0">
                        <TextBlock Text="일일 루틴 로그" FontSize="20" FontWeight="Bold"/>
                        <TextBlock Text="하루 동안 발생한 훈련/이벤트 로그입니다." FontSize="12" Foreground="#9FA9C4" Margin="0,4,0,0"/>
                        <TextBlock x:Name="DailyLogTitleText" FontSize="14" Foreground="#C9CEDD" Margin="0,6,0,0"/>
                    </StackPanel>
                    <ScrollViewer Grid.Row="1" Margin="0,12,0,12" VerticalScrollBarVisibility="Auto">
                        <ItemsControl x:Name="DailyLogEntriesList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#1E2434" CornerRadius="4" Padding="8" Margin="0,2,0,2">
                                        <TextBlock Text="{Binding}" TextWrapping="Wrap" Foreground="#FFFFFF"/>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="확인" Width="160" Click="DailyLogCloseButton_OnClick"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!-- Match Overlay -->
        <Grid x:Name="MatchOverlay" Background="#CC000000" Visibility="Collapsed">
            <Border Padding="32" Background="#121725" CornerRadius="12" Width="1360" Height="820" HorizontalAlignment="Center" VerticalAlignment="Center">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0">
                        <TextBlock Text="경기 진행 중" FontSize="22" FontWeight="Bold"/>
                        <TextBlock x:Name="MatchOpponentText" FontSize="16" Margin="0,4,0,0"/>
                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                            <TextBlock Text="이닝" Width="80"/>
                            <TextBlock x:Name="MatchInningText"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                            <TextBlock Text="카운트" Width="80"/>
                            <TextBlock x:Name="MatchCountText"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                            <TextBlock Text="상황" Width="80"/>
                            <TextBlock x:Name="MatchSituationText"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                            <TextBlock Text="스코어" Width="80"/>
                            <TextBlock x:Name="MatchScoreText"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                            <TextBlock Text="진행" Width="80"/>
                            <TextBlock x:Name="MatchProgressText"/>
                        </StackPanel>
                    </StackPanel>

                    <Grid Grid.Row="1" Margin="0,16,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Padding="12" Background="#161C2B" CornerRadius="6" Margin="0,0,8,10">
                                <StackPanel>
                                    <TextBlock Text="우리 투수" FontWeight="Bold"/>
                                    <TextBlock x:Name="MatchPitcherNameText" FontSize="18" FontWeight="Bold" Margin="0,2,0,0"/>
                                    <TextBlock x:Name="MatchPitcherCommandText" FontSize="12" Foreground="#B0BCD6"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0" VerticalAlignment="Center">
                                        <TextBlock Text="체력" Width="40"/>
                                        <ProgressBar x:Name="MatchPitcherStaminaBar" Width="200" Height="12" Maximum="100"/>
                                        <TextBlock x:Name="MatchPitcherStaminaValue" Margin="8,0,0,0"/>
                                    </StackPanel>
                                    <TextBlock x:Name="MatchPitcherFocusText" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="1" Padding="12" Background="#161C2B" CornerRadius="6" Margin="8,0,0,10">
                                <StackPanel>
                                    <TextBlock Text="상대 타자" FontWeight="Bold"/>
                                    <TextBlock x:Name="MatchBatterNameText" FontSize="18" FontWeight="Bold" Margin="0,2,0,0"/>
                                    <TextBlock x:Name="MatchBatterTraitsText" FontSize="12" Foreground="#B0BCD6"/>
                                    <TextBlock x:Name="MatchBatterThreatText" Margin="0,4,0,0"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                        <TextBlock Text="컨택" Width="50"/>
                                        <TextBlock x:Name="MatchBatterContactText"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="장타" Width="50"/>
                                        <TextBlock x:Name="MatchBatterPowerText"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="선구" Width="50"/>
                                        <TextBlock x:Name="MatchBatterEyeText"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <Grid Grid.Row="1" Margin="0,20,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="4*"/>
                                <ColumnDefinition Width="3*"/>
                            </Grid.ColumnDefinitions>

                            <Grid Grid.Column="0" Margin="0,0,16,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <StackPanel Grid.Row="0">
                                    <TextBlock Text="경기 로그" FontSize="16" FontWeight="Bold" Foreground="#FFFFFF"/>
                                    <TextBox x:Name="MatchOverlayLogTextBox"
                                             Margin="0,6,0,0"
                                             MinHeight="360"
                                             AcceptsReturn="True"
                                             TextWrapping="Wrap"
                                             IsReadOnly="True"
                                             Foreground="#FFFFFF"
                                             Background="#151A28"
                                             BorderBrush="#23293A"
                                             VerticalScrollBarVisibility="Auto"
                                             HorizontalScrollBarVisibility="Disabled"/>
                                </StackPanel>

                                <Border Grid.Row="1" Margin="0,20,0,0" Padding="16" Background="#1B1F2D" CornerRadius="6">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <TextBlock Text="투구 선택" FontSize="16" FontWeight="Bold" Foreground="#FFFFFF"/>

                                        <TextBlock Text="구종" Grid.Row="1" Margin="0,10,0,0" VerticalAlignment="Center" Foreground="#FFFFFF"/>
                                        <ComboBox x:Name="MatchPitchTypeCombo" Grid.Row="1" Grid.Column="1" Width="240" Margin="12,10,0,0"/>

                                        <TextBlock Text="타깃 존" Grid.Row="2" Margin="0,8,0,0" VerticalAlignment="Center" Foreground="#FFFFFF"/>
                                        <ComboBox x:Name="MatchTargetZoneCombo" Grid.Row="2" Grid.Column="1" Width="240" Margin="12,8,0,0"/>

                                        <TextBlock Text="공략 의도" Grid.Row="3" Margin="0,8,0,0" VerticalAlignment="Center" Foreground="#FFFFFF"/>
                                        <ComboBox x:Name="MatchPitchIntentCombo" Grid.Row="3" Grid.Column="1" Width="240" Margin="12,8,0,0">
                                            <ComboBoxItem Content="정면 승부"/>
                                            <ComboBoxItem Content="유인구"/>
                                            <ComboBoxItem Content="낚시 승부"/>
                                        </ComboBox>

                                        <StackPanel Grid.Row="4" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="0,16,0,0" HorizontalAlignment="Left">
                                            <Button x:Name="MatchSimulateButton" Content="투구 시뮬레이션" Width="200" Margin="0,0,8,0" Click="MatchSimulateButton_OnClick"/>
                                            <Button x:Name="MatchCloseButton" Content="경기 종료" Width="200" IsEnabled="False" Click="MatchCloseButton_OnClick"/>
                                        </StackPanel>

                                        <Border x:Name="CoachPromptPanel" Grid.Row="4" Grid.ColumnSpan="2" Margin="0,68,0,0" Padding="10" Background="#2A3247" CornerRadius="6" Visibility="Collapsed">
                                            <StackPanel>
                                                <TextBlock Text="감독 결정" FontWeight="Bold"/>
                                                <TextBlock x:Name="CoachPromptText" Margin="0,6,0,10" TextWrapping="Wrap"/>
                                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                                    <Button Content="강판 수락" Width="110" Margin="0,0,6,0" Click="CoachPromptAcceptButton_OnClick"/>
                                                    <Button Content="조금 더" Width="110" Click="CoachPromptDeclineButton_OnClick"/>
                                                </StackPanel>
                                            </StackPanel>
                                        </Border>
                                    </Grid>
                                </Border>
                            </Grid>

                            <Border Grid.Column="1" Padding="16" Background="#161C2B" CornerRadius="6">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <Grid Grid.Row="0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="360"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Margin="0,0,16,0">
                                            <TextBlock Text="투구 궤적" FontSize="16" FontWeight="Bold" Foreground="#FFFFFF"/>
                                            <Grid Width="360" Height="420" Margin="0,8,0,0" ClipToBounds="True">
                                                <Canvas Width="360" Height="420" Background="#111729">
                                                    <Rectangle Canvas.Left="110" Canvas.Top="80" Width="180" Height="240" Stroke="#5B6483" StrokeThickness="2.2" Fill="#182036"/>
                                                    <Line X1="170" Y1="80" X2="170" Y2="320" Stroke="#3C425A" StrokeThickness="1.2"/>
                                                    <Line X1="230" Y1="80" X2="230" Y2="320" Stroke="#3C425A" StrokeThickness="1.2"/>
                                                    <Line X1="110" Y1="160" X2="290" Y2="160" Stroke="#3C425A" StrokeThickness="1.2"/>
                                                    <Line X1="110" Y1="240" X2="290" Y2="240" Stroke="#3C425A" StrokeThickness="1.2"/>
                                                </Canvas>
                                                <ItemsControl x:Name="PitchMarkerItems" IsHitTestVisible="False">
                                                    <ItemsControl.ItemsPanel>
                                                        <ItemsPanelTemplate>
                                                            <Canvas Width="360" Height="420"/>
                                                        </ItemsPanelTemplate>
                                                    </ItemsControl.ItemsPanel>
                                                    <ItemsControl.ItemContainerStyle>
                                                        <Style TargetType="ContentPresenter">
                                                            <Setter Property="Canvas.Left" Value="{Binding CanvasLeft}"/>
                                                            <Setter Property="Canvas.Top" Value="{Binding CanvasTop}"/>
                                                        </Style>
                                                    </ItemsControl.ItemContainerStyle>
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Grid>
                                                                <Ellipse Width="26" Height="26" Fill="{Binding FillBrush}" Stroke="#0B0E16" StrokeThickness="1.5" Opacity="0.95"/>
                                                                <TextBlock Text="{Binding SequenceText}" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold" Foreground="#0B0E16"/>
                                                            </Grid>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </Grid>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="투구 결과" FontSize="16" FontWeight="Bold" Foreground="#FFFFFF"/>
                                            <ScrollViewer Margin="0,8,0,0" VerticalScrollBarVisibility="Auto" Height="380">
                                                <ItemsControl x:Name="PitchResultList">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Border Background="#1E2538" CornerRadius="6" Padding="10" Margin="0,4,0,4">
                                                                <Grid>
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="Auto"/>
                                                                        <ColumnDefinition Width="*"/>
                                                                        <ColumnDefinition Width="Auto"/>
                                                                    </Grid.ColumnDefinitions>
                                                                    <Grid>
                                                                        <Ellipse Width="28" Height="28" Fill="{Binding FillBrush}" Stroke="#0B0E16" StrokeThickness="1.4"/>
                                                                        <TextBlock Text="{Binding SequenceText}" Foreground="#0B0E16" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                    </Grid>
                                                                    <StackPanel Grid.Column="1" Margin="14,0,0,0">
                                                                        <TextBlock Text="{Binding ResultLabel}" FontWeight="Bold" Foreground="#F7F8FF"/>
                                                                        <TextBlock Text="{Binding DetailText}" FontSize="11.5" Foreground="#FFFFFF" TextWrapping="Wrap"/>
                                                                    </StackPanel>
                                                                    <TextBlock Grid.Column="2" Text="{Binding CountLabel}" FontSize="11" Foreground="#FFFFFF" VerticalAlignment="Top"/>
                                                                </Grid>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </ScrollViewer>
                                        </StackPanel>
                                    </Grid>

                                </Grid>
                            </Border>
                        </Grid>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
