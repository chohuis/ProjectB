<Window x:Class="CareerSimTextDemo.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Career Sim Text Prototype" Height="900" Width="1400"
        Background="#0E1017" Foreground="#F5F5F5"
        PreviewKeyDown="MainWindow_OnPreviewKeyDown">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <!-- FM24-ish: crisp dark panels + subtle accent -->
        <Color x:Key="AccentColor">#5ED6B8</Color>
        <Color x:Key="AccentHoverColor">#7FE3CB</Color>
        <Color x:Key="PanelColor">#1B1F2D</Color>
        <Color x:Key="PanelAltColor">#20273A</Color>
        <Color x:Key="PanelEdgeColor">#2A3247</Color>

        <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}"/>
        <SolidColorBrush x:Key="AccentHoverBrush" Color="{StaticResource AccentHoverColor}"/>
        <SolidColorBrush x:Key="PanelBrush" Color="{StaticResource PanelColor}"/>
        <SolidColorBrush x:Key="PanelAltBrush" Color="{StaticResource PanelAltColor}"/>
        <SolidColorBrush x:Key="PanelEdgeBrush" Color="{StaticResource PanelEdgeColor}"/>

        <Style TargetType="Button">
            <Setter Property="Background" Value="#26314A"/>
            <Setter Property="Foreground" Value="#F5F5F5"/>
            <Setter Property="BorderBrush" Value="{StaticResource PanelEdgeBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonRoot"
                                CornerRadius="8"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonRoot" Property="Background" Value="#2F3E5F"/>
                                <Setter TargetName="ButtonRoot" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonRoot" Property="Background" Value="#22324F"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonRoot" Property="Opacity" Value="0.55"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Expander">
            <Setter Property="Foreground" Value="#F5F5F5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Expander">
                        <Border Background="#23293C" CornerRadius="6" BorderBrush="#2A3247" BorderThickness="1">
                            <DockPanel>
                                <ToggleButton x:Name="HeaderSite"
                                              DockPanel.Dock="Top"
                                              Background="Transparent"
                                              BorderThickness="0"
                                              Padding="10,8"
                                              Content="{TemplateBinding Header}"
                                              FontWeight="SemiBold"
                                              Foreground="{TemplateBinding Foreground}"
                                              IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}}"
                                              Focusable="False"/>
                                <ContentPresenter x:Name="ExpandSite"
                                                  Margin="10,0,10,10"
                                                  Visibility="Collapsed"/>
                            </DockPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsExpanded" Value="True">
                                <Setter TargetName="ExpandSite" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="HeaderSite" Property="Foreground" Value="{StaticResource AccentBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Grid x:Name="RootGrid">
        <Grid x:Name="MainLayout" Margin="18">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" Padding="18" CornerRadius="8" Background="#1B1F2D">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Width="420">
                        <TextBlock Text="Career Baseball Life - Text Demo" FontSize="24" FontWeight="Bold"/>
                        <TextBlock x:Name="PlayerSummaryText" Margin="0,8,0,0"/>
                        <TextBlock x:Name="PitchInfoText" Margin="0,4,0,0"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <TextBlock Text="현재 진행" HorizontalAlignment="Right"/>
                        <TextBlock x:Name="CurrentDayText" FontSize="20" FontWeight="Bold" HorizontalAlignment="Right"/>
                        <TextBlock x:Name="HeaderMatchStatusText" Margin="0,6,0,0" Foreground="#9FA9C4" HorizontalAlignment="Right"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
                            <Button x:Name="HeaderMessageButton" Content="메시지 0" Width="110" Margin="0,0,8,0" Click="HeaderMessageButton_OnClick"/>
                            <Button x:Name="HeaderMatchButton" Content="경기 보기" Width="110" Click="HeaderMatchButton_OnClick"/>
                        </StackPanel>
                        <Button x:Name="AdvanceButton" Content="진행" Width="160" Margin="0,10,0,0" HorizontalAlignment="Right" Click="AdvanceButton_OnClick"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Main Content -->
            <Grid Grid.Row="1" Margin="0,16,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="220"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Main Menu -->
                <Border Padding="14" CornerRadius="8" Background="#1B1F2D">
                    <StackPanel>
                        <TextBlock Text="메인 메뉴" FontSize="16" FontWeight="Bold"/>
                        <ListBox x:Name="SectionList" SelectionChanged="SectionList_OnSelectionChanged"
                                 Background="Transparent" BorderThickness="0" Margin="0,8,0,0">
                            <ListBox.Resources>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Padding" Value="0"/>
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListBoxItem">
                                                <Border x:Name="Root" Background="#252A3B" CornerRadius="6" Margin="0,4,0,4">
                                                    <ContentPresenter Margin="12,8"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsSelected" Value="True">
                                                        <Setter TargetName="Root" Property="Background" Value="#3B4A6D"/>
                                                    </Trigger>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Root" Property="Background" Value="#30384F"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListBox.Resources>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Title}" FontSize="14" FontWeight="Bold" Margin="4,0"/>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </StackPanel>
                </Border>

                <!-- Detail Panels -->
                <Grid Grid.Column="1" Margin="16,0,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Home Panel -->
                    <Grid x:Name="HomePanel" Grid.Row="0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Border Padding="16" CornerRadius="8" Background="#1B1F2D">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="선수 프로필" FontSize="18" FontWeight="Bold"/>
                                    <TextBlock x:Name="InfoSchoolText" Margin="0,6,0,0" FontSize="14"/>
                                    <TextBlock x:Name="InfoPitchStyleText" FontSize="12" Margin="0,2,0,0"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="구종 구성" FontWeight="Bold"/>
                                    <ItemsControl x:Name="PitchList" Margin="0,4,0,0">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text=">" Margin="0,0,4,0"/>
                                                    <TextBlock Text="{Binding}"/>
                                                </StackPanel>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Border Grid.Row="1" Margin="0,12,0,0" Padding="16" CornerRadius="8" Background="#1B1F2D">
                            <StackPanel>
                                <TextBlock Text="학년 · 시즌 진행" FontSize="16" FontWeight="Bold"/>
                                <WrapPanel Margin="0,8,0,0" ItemWidth="220">
                                    <StackPanel Margin="0,0,16,8">
                                        <TextBlock Text="학년" FontWeight="Bold"/>
                                        <TextBlock x:Name="LoopAcademicYearText" FontSize="14"/>
                                    </StackPanel>
                                    <StackPanel Margin="0,0,16,8">
                                        <TextBlock Text="현재 날짜" FontWeight="Bold"/>
                                        <TextBlock x:Name="LoopCalendarText" FontSize="14"/>
                                    </StackPanel>
                                    <StackPanel Margin="0,0,16,8">
                                        <TextBlock Text="주차" FontWeight="Bold"/>
                                        <TextBlock x:Name="LoopWeekText" FontSize="14"/>
                                    </StackPanel>
                                    <StackPanel Margin="0,0,16,8">
                                        <TextBlock Text="시즌 단계" FontWeight="Bold"/>
                                        <TextBlock x:Name="LoopPhaseText" FontSize="14"/>
                                    </StackPanel>
                                    <StackPanel Margin="0,0,16,8">
                                        <TextBlock Text="멘탈/분위기" FontWeight="Bold"/>
                                        <TextBlock x:Name="LoopMoodText" FontSize="14"/>
                                    </StackPanel>
                                    <StackPanel Margin="0,0,16,8">
                                        <TextBlock Text="훈련/루틴" FontWeight="Bold"/>
                                        <TextBlock x:Name="LoopTrainingText" FontSize="14"/>
                                    </StackPanel>
                                </WrapPanel>
                                <StackPanel Margin="0,8,0,0">
                                    <TextBlock Text="다가오는 이벤트" FontWeight="Bold"/>
                                    <TextBlock x:Name="LoopUpcomingText" FontSize="14" TextWrapping="Wrap"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <Grid Grid.Row="2" Margin="0,12,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Padding="16" Background="#1B1F2D" CornerRadius="8" Margin="0,0,12,0">
                                <StackPanel>
                                    <TextBlock Text="최근 5경기 기록" FontSize="16" FontWeight="Bold"/>
                                    <ItemsControl x:Name="RecentMatchList" Margin="0,10,0,0">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="#23293C" CornerRadius="4" Padding="8" Margin="0,0,0,6">
                                                    <TextBlock Text="{Binding}" TextWrapping="Wrap"/>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="1" Padding="16" Background="#1B1F2D" CornerRadius="8">
                                <StackPanel>
                                    <TextBlock Text="다가올 주요 이벤트" FontSize="16" FontWeight="Bold"/>
                                    <TextBlock Text="루프 예정과 동일한 타임라인을 요약합니다." Margin="0,6,0,0" Foreground="#9099B5"/>
                                    <ItemsControl x:Name="HomeUpcomingList" Margin="0,10,0,0">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="#23293C" CornerRadius="4" Padding="8" Margin="0,0,0,6">
                                                    <StackPanel>
                                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
                                                            <TextBlock Text="{Binding CountdownLabel}" Width="60" Foreground="#FFD66E" FontWeight="Bold"/>
                                                            <TextBlock Text="{Binding Label}" Width="80" Foreground="#C9CEDD"/>
                                                            <TextBlock Text="{Binding Summary}" Margin="8,0,0,0"/>
                                                        </StackPanel>
                                                        <TextBlock Text="{Binding Preview}" FontSize="11" Foreground="#A5B1CA" TextWrapping="Wrap"/>
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>
                        </Grid>

                    
                        <Border x:Name="HomeMessageSummaryPanel" Grid.Row="4" Margin="0,12,0,0" Padding="16" CornerRadius="8" Background="#1B1F2D">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="메시지 요약" FontSize="16" FontWeight="Bold"/>
                                <TextBlock x:Name="HomeMessageCountText" Grid.Column="1" Foreground="#9FA9C4" VerticalAlignment="Center"/>
                                <StackPanel Grid.Row="1" Grid.ColumnSpan="2" Margin="0,8,0,0">
                                    <TextBlock x:Name="HomeMessageEmptyText" Text="대기 메시지가 없습니다." Foreground="#9099B5" Margin="0,0,0,8"/>
                                    <ItemsControl x:Name="HomeMessageList">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="#23293C" CornerRadius="6" Padding="10" Margin="0,0,0,6">
                                                    <StackPanel>
                                                        <TextBlock Text="{Binding Title}" FontWeight="Bold"/>
                                                        <TextBlock Text="{Binding Description}" FontSize="11" Foreground="#A5B1CA" TextWrapping="Wrap"/>
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Grid>
                        </Border>

                    </Grid>

                    <!-- Messages Panel -->
                    <Grid x:Name="MessagesPanel" Grid.Row="0" Visibility="Collapsed">
                        <Border Padding="16" CornerRadius="8" Background="#1B1F2D">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <StackPanel Grid.Row="0">
                                    <TextBlock Text="메시지 인박스" FontSize="18" FontWeight="Bold"/>
                                    <TextBlock x:Name="MessagesEmptyText" Text="대기 메시지가 없습니다." Margin="0,6,0,0" Foreground="#9099B5"/>
                                </StackPanel>
                                <ScrollViewer Grid.Row="1" Margin="0,12,0,0" VerticalScrollBarVisibility="Auto">
                                    <StackPanel>
                                        <TextBlock Text="일일 로그" FontSize="14" FontWeight="Bold" Margin="0,0,0,8"/>
                                        <ItemsControl x:Name="MessageLogList">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Expander Header="{Binding Title}"
                                                              IsExpanded="{Binding IsLatest}"
                                                              Background="#23293C"
                                                              Foreground="#F5F5F5"
                                                              Margin="0,0,0,8">
                                                        <ItemsControl ItemsSource="{Binding Entries}">
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate>
                                                                    <Border Background="#1E2434" CornerRadius="4" Padding="6" Margin="0,2,0,2">
                                                                        <TextBlock Text="{Binding}" TextWrapping="Wrap" Foreground="#FFFFFF"/>
                                                                    </Border>
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>
                                                    </Expander>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>

                                        <TextBlock Text="선택 메시지" FontSize="14" FontWeight="Bold" Margin="0,12,0,8"/>
                                        <ItemsControl x:Name="MessagesList">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Background="#20273A" CornerRadius="8" Padding="14" Margin="0,0,0,10">
                                                        <StackPanel>
                                                            <TextBlock Text="{Binding Title}" FontSize="15" FontWeight="Bold"/>
                                                            <TextBlock Text="{Binding Description}" Margin="0,6,0,10" FontSize="12" Foreground="#C1C9DD" TextWrapping="Wrap"/>
                                                            <ItemsControl ItemsSource="{Binding Options}">
                                                                <ItemsControl.ItemTemplate>
                                                                    <DataTemplate>
                                                                        <Border Background="#1A2233" CornerRadius="6" Padding="10" Margin="0,0,0,8">
                                                                            <StackPanel>
                                                                                <TextBlock Text="{Binding Title}" FontWeight="Bold"/>
                                                                                <TextBlock Text="{Binding Description}" Margin="0,4,0,8" FontSize="11" Foreground="#A5B1CA" TextWrapping="Wrap"/>
                                                                                <Button Content="선택"
                                                                                        Tag="{Binding DataContext.Id, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                                        Click="MessageOptionButton_OnClick"/>
                                                                            </StackPanel>
                                                                        </Border>
                                                                    </DataTemplate>
                                                                </ItemsControl.ItemTemplate>
                                                            </ItemsControl>
                                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,6,0,0">
                                                                <Button Content="기본값 진행" Width="160" Click="MessageDefaultButton_OnClick"/>
                                                            </StackPanel>
                                                        </StackPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </ScrollViewer>
                            </Grid>
                        </Border>
                    </Grid>

                    <!-- Info Panel -->
                    <Grid x:Name="InfoPanel" Grid.Row="0" Visibility="Collapsed">
                        <Border Padding="16" CornerRadius="8" Background="#1B1F2D">
                            <StackPanel>
                                <TextBlock Text="신체 · 기술 · 멘탈 능력치" FontSize="16" FontWeight="Bold"/>
                                <Grid Margin="0,12,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <Border Padding="12" Background="#20273A" CornerRadius="8" Margin="0,0,12,0">
                                        <StackPanel>
                                            <TextBlock Text="신체 능력치" FontWeight="Bold" FontSize="14"/>
                                            <ListView x:Name="PhysicalStatsList" Margin="0,8,0,0" Background="#20273A" BorderThickness="0" Foreground="#F5F5F5">
                                                <ListView.View>
                                                    <GridView>
                                                        <GridViewColumn Header="항목" DisplayMemberBinding="{Binding Label}" Width="180"/>
                                                        <GridViewColumn Header="값" Width="70">
                                                            <GridViewColumn.CellTemplate>
                                                                <DataTemplate>
                                                                    <TextBlock Text="{Binding Value, StringFormat=F1}" HorizontalAlignment="Right"/>
                                                                </DataTemplate>
                                                            </GridViewColumn.CellTemplate>
                                                        </GridViewColumn>
                                                    </GridView>
                                                </ListView.View>
                                            </ListView>
                                        </StackPanel>
                                    </Border>

                                    <Border Grid.Column="1" Padding="12" Background="#20273A" CornerRadius="8" Margin="0,0,12,0">
                                        <StackPanel>
                                            <TextBlock Text="기술 능력치" FontWeight="Bold" FontSize="14"/>
                                            <ListView x:Name="TechnicalStatsList" Margin="0,8,0,0" Background="#20273A" BorderThickness="0" Foreground="#F5F5F5">
                                                <ListView.View>
                                                    <GridView>
                                                        <GridViewColumn Header="항목" DisplayMemberBinding="{Binding Label}" Width="200"/>
                                                        <GridViewColumn Header="값" Width="70">
                                                            <GridViewColumn.CellTemplate>
                                                                <DataTemplate>
                                                                    <TextBlock Text="{Binding Value, StringFormat=F1}" HorizontalAlignment="Right"/>
                                                                </DataTemplate>
                                                            </GridViewColumn.CellTemplate>
                                                        </GridViewColumn>
                                                    </GridView>
                                                </ListView.View>
                                            </ListView>
                                        </StackPanel>
                                    </Border>

                                    <Border Grid.Column="2" Padding="12" Background="#20273A" CornerRadius="8">
                                        <StackPanel>
                                            <TextBlock Text="멘탈/기타" FontWeight="Bold" FontSize="14"/>
                                            <ListView x:Name="MentalStatsList" Margin="0,8,0,0" Background="#20273A" BorderThickness="0" Foreground="#F5F5F5">
                                                <ListView.View>
                                                    <GridView>
                                                        <GridViewColumn Header="항목" DisplayMemberBinding="{Binding Label}" Width="200"/>
                                                        <GridViewColumn Header="값" Width="70">
                                                            <GridViewColumn.CellTemplate>
                                                                <DataTemplate>
                                                                    <TextBlock Text="{Binding Value, StringFormat=F1}" HorizontalAlignment="Right"/>
                                                                </DataTemplate>
                                                            </GridViewColumn.CellTemplate>
                                                        </GridViewColumn>
                                                    </GridView>
                                                </ListView.View>
                                            </ListView>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                                <Border Margin="0,16,0,0" Padding="12" Background="#20273A" CornerRadius="8">
                                    <StackPanel>
                                        <TextBlock Text="선수 일정 타임라인" FontSize="16" FontWeight="Bold"/>
                                        <ItemsControl x:Name="InfoLoopList" Margin="0,10,0,0">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <StackPanel Margin="0,2,0,6">
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Text="{Binding Label}" Width="80" Foreground="#C9CEDD"/>
                                                            <TextBlock Text="{Binding CountdownLabel}" Width="70" Foreground="#FFD66E"/>
                                                            <TextBlock Text="{Binding Summary}" Margin="8,0,0,0"/>
                                                        </StackPanel>
                                                        <TextBlock Text="{Binding Preview}" FontSize="11" Foreground="#98A2C1" TextWrapping="Wrap"/>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- Roster Panel -->
                    <Grid x:Name="RosterPanel" Grid.Row="0" Visibility="Collapsed">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Border Padding="16" CornerRadius="8" Background="#1B1F2D">
                            <StackPanel>
                                <TextBlock Text="감독 &amp; 코치진" FontSize="16" FontWeight="Bold"/>
                                <ItemsControl x:Name="RosterStaffList" Margin="0,8,0,0">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" Margin="0,2,0,2">
                                                <TextBlock Text="{Binding Role}" Width="90" FontWeight="Bold"/>
                                                <TextBlock Text="{Binding Name}" Width="120"/>
                                                <TextBlock Text="{Binding Specialty}" Width="110" Foreground="#C0C6D9"/>
                                                <TextBlock Text="{Binding RatingSummary}" Foreground="#8EA0C9"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <TextBlock Text="주장/부주장 후보 이벤트는 추후 업데이트 예정입니다." FontSize="12" Foreground="#C0C6D9" Margin="0,8,0,0" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                        <Grid Grid.Row="1" Margin="0,12,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width="3*"/>
                            </Grid.ColumnDefinitions>
                            <Border Padding="14" Background="#1B1F2D" CornerRadius="8" Margin="0,0,12,0">
                                <StackPanel>
                                    <TextBlock Text="보유 선수" FontSize="16" FontWeight="Bold"/>
                                    <ListView x:Name="RosterList" Margin="0,10,0,0" Height="360" Background="#1B1F2D" BorderThickness="0" Foreground="#F5F5F5"
                                              SelectionChanged="RosterList_OnSelectionChanged"
                                              MouseDoubleClick="RosterList_OnMouseDoubleClick">
                                        <ListView.View>
                                            <GridView>
                                                <GridViewColumn Header="이름" DisplayMemberBinding="{Binding Name}" Width="130"/>
                                                <GridViewColumn Header="OVR" DisplayMemberBinding="{Binding Overall}" Width="50"/>
                                                <GridViewColumn Header="역할" DisplayMemberBinding="{Binding Role}" Width="180"/>
                                                <GridViewColumn Header="학년/상태" DisplayMemberBinding="{Binding StatusLabel}" Width="120"/>
                                                <GridViewColumn Header="태그" DisplayMemberBinding="{Binding Tags}" Width="140"/>
                                            </GridView>
                                        </ListView.View>
                                    </ListView>
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="1" Padding="16" Background="#1B1F2D" CornerRadius="8">
                                <StackPanel>
                                    <TextBlock Text="상세 정보" FontSize="16" FontWeight="Bold"/>
                                    <TextBlock x:Name="RosterDetailNameText" FontSize="22" FontWeight="Bold" Margin="0,6,0,0"/>
                                    <TextBlock x:Name="RosterDetailMetaText" FontSize="13" Foreground="#C0C6D9" Margin="0,2,0,0"/>
                                    <TextBlock x:Name="RosterDetailArchetypeText" FontSize="13" Margin="0,2,0,0"/>
                                    <TextBlock x:Name="RosterDetailTagsText" FontSize="12" Foreground="#E0B973" Margin="0,2,0,0"/>
                                    <TextBlock x:Name="RosterDetailOverallText" FontSize="13" Margin="0,6,0,0"/>
                                    <TextBlock x:Name="RosterDetailPlaceholder" Text="선수를 선택하면 상세 능력치가 표시됩니다." Margin="0,20,0,0" Foreground="#7C8299"/>
                                    <Grid Margin="0,12,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="신체" FontWeight="Bold"/>
                                            <ItemsControl x:Name="RosterPhysicalList" Margin="0,4,0,0">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <DockPanel>
                                                            <TextBlock Text="{Binding Label}" Width="100"/>
                                                            <TextBlock Text="{Binding Value}" HorizontalAlignment="Right"/>
                                                        </DockPanel>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Margin="12,0,0,0">
                                            <TextBlock Text="투구" FontWeight="Bold"/>
                                            <ItemsControl x:Name="RosterPitchingList" Margin="0,4,0,0">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <DockPanel>
                                                            <TextBlock Text="{Binding Label}" Width="120"/>
                                                            <TextBlock Text="{Binding Value}" HorizontalAlignment="Right"/>
                                                        </DockPanel>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                        <StackPanel Grid.Column="2" Margin="12,0,0,0">
                                            <TextBlock Text="타격/수비" FontWeight="Bold"/>
                                            <ItemsControl x:Name="RosterBattingList" Margin="0,4,0,0">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <DockPanel>
                                                            <TextBlock Text="{Binding Label}" Width="130"/>
                                                            <TextBlock Text="{Binding Value}" HorizontalAlignment="Right"/>
                                                        </DockPanel>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </Grid>
                                    <Grid Margin="0,12,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="멘탈" FontWeight="Bold"/>
                                            <ItemsControl x:Name="RosterMentalList" Margin="0,4,0,0">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <DockPanel>
                                                            <TextBlock Text="{Binding Label}" Width="100"/>
                                                            <TextBlock Text="{Binding Value}" HorizontalAlignment="Right"/>
                                                        </DockPanel>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Margin="12,0,0,0">
                                            <TextBlock Text="잠재/성향" FontWeight="Bold"/>
                                            <ItemsControl x:Name="RosterHiddenList" Margin="0,4,0,0">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <DockPanel>
                                                            <TextBlock Text="{Binding Label}" Width="130"/>
                                                            <TextBlock Text="{Binding Value}" HorizontalAlignment="Right"/>
                                                        </DockPanel>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </Grid>

                    </Grid>

                    <!-- Training Panel -->
                    <Grid x:Name="TrainingPanel" Grid.Row="0" Visibility="Collapsed">
                        <Border Padding="16" CornerRadius="8" Background="#1B1F2D">
                            <StackPanel>
                                <TextBlock Text="루틴 관리" FontSize="18" FontWeight="Bold"/>
                                <TextBlock Text="기본 루틴 3종을 카드로 관리하고 주간 캘린더에 날짜별로 배치합니다." FontSize="12" Foreground="#9FA9C4" Margin="0,4,0,12"/>

                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,8">
                                    <Button Content="커스텀 루틴 추가" Click="RoutineAddButton_OnClick"/>
                                </StackPanel>
                                <ItemsControl x:Name="RoutineCardList" Margin="0,0,0,12">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="#23293C" CornerRadius="10" Padding="14" Margin="0,0,12,12" Width="320">
                                                <Grid>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="*"/>
                                                        <RowDefinition Height="Auto"/>
                                                    </Grid.RowDefinitions>
                                                    <StackPanel Grid.Row="0" Orientation="Horizontal">
                                                        <StackPanel Width="210">
                                                            <TextBlock Text="{Binding Name}" FontSize="14" FontWeight="Bold"/>
                                                            <TextBlock Text="{Binding Subtitle}" FontSize="11" Foreground="#9FA9C4"/>
                                                            <TextBlock Text="{Binding Focus}" FontSize="11" Foreground="#FFC778"/>
                                                        </StackPanel>
                                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="8,0,0,0">
                                                            <Button Content="편집" Tag="{Binding Id}" Width="46" Margin="0,0,4,0" Click="RoutineEditButton_OnClick"/>
                                                            <Button Content="삭제" Tag="{Binding Id}" Width="46" Margin="0,0,4,0" Click="RoutineDeleteButton_OnClick"
                                                                    Visibility="{Binding IsCustom, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                                            <Button Content="복원" Tag="{Binding Id}" Width="46" Click="RoutineResetButton_OnClick"
                                                                    Visibility="{Binding CanReset, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                                        </StackPanel>
                                                    </StackPanel>
                                                    <StackPanel Grid.Row="1" Margin="0,6,0,0">
                                                        <ProgressBar Value="{Binding Mastery, Mode=OneWay}" Maximum="100" Height="8" Foreground="#4A90E2" Background="#1B1F2D"/>
                                                        <TextBlock Text="{Binding TierLabel}" FontSize="11" Foreground="#B4C3FF" Margin="0,4,0,0"/>
                                                    </StackPanel>
                                                    <StackPanel Grid.Row="2" Margin="0,8,0,8">
                                                        <TextBlock Text="{Binding Description}" FontSize="11" TextWrapping="Wrap" Foreground="#C9CEDD"/>
                                                        <StackPanel Margin="0,8,0,0">
                                                            <TextBlock Text="{Binding MorningName}" FontSize="11"/>
                                                            <TextBlock Text="{Binding AfternoonName}" FontSize="11"/>
                                                            <TextBlock Text="{Binding EveningName}" FontSize="11"/>
                                                        </StackPanel>
                                                    </StackPanel>
                                                    <StackPanel Grid.Row="3">
                                                        <Button Content="선택 날짜 배치" Tag="{Binding Id}" Click="RoutineCardApplyButton_OnClick"/>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,8">
                                    <TextBlock Text="주간 루틴 캘린더" FontSize="16" FontWeight="Bold"/>
                                    <StackPanel Orientation="Horizontal" Margin="16,0,0,0" VerticalAlignment="Center">
                                        <Button Content="◀" Width="36" Click="RoutineWeekPrevButton_OnClick"/>
                                        <TextBlock x:Name="RoutineWeekLabel" FontSize="14" FontWeight="Bold" Margin="8,0,8,0"/>
                                        <Button Content=">" Width="36" Click="RoutineWeekNextButton_OnClick"/>
                                    </StackPanel>
                                </StackPanel>
                                <TextBlock x:Name="SelectedRoutineDayText" FontSize="12" Foreground="#9FA9C4" Margin="0,0,0,8"/>

                                <ItemsControl x:Name="RoutineWeekGrid">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <UniformGrid Columns="7"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Button Margin="4" Padding="8" Click="RoutineDayButton_OnClick">
                                                <Button.Style>
                                                    <Style TargetType="Button">
                                                        <Setter Property="Background" Value="#23293C"/>
                                                        <Setter Property="BorderBrush" Value="#2F354A"/>
                                                        <Setter Property="Foreground" Value="#F5F5F5"/>
                                                        <Setter Property="BorderThickness" Value="1"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                                <Setter Property="Background" Value="#2F3A57"/>
                                                                <Setter Property="BorderBrush" Value="#4A90E2"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding IsLocked}" Value="True">
                                                                <Setter Property="Opacity" Value="0.5"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Button.Style>
                                                <StackPanel>
                                                    <TextBlock Text="{Binding Label}" FontWeight="Bold"/>
                                                    <TextBlock Text="{Binding RoutineName}" FontSize="11" Foreground="#C5D2FF"/>
                                                    <TextBlock Text="{Binding LockReason}" FontSize="10" Foreground="#FF9A7A" TextWrapping="Wrap"
                                                               Visibility="{Binding IsLocked, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                                </StackPanel>
                                            </Button>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <StackPanel Orientation="Horizontal" Margin="0,12,0,0" HorizontalAlignment="Left">
                                    <Button Content="감독 추천 · 밸런스" Tag="balanced" Click="CoachRecommendationButton_OnClick" Margin="0,0,8,0"/>
                                    <Button Content="감독 추천 · 실전 대비" Tag="match" Click="CoachRecommendationButton_OnClick" Margin="0,0,8,0"/>
                                    <Button Content="감독 추천 · 학업/멘탈" Tag="academic" Click="CoachRecommendationButton_OnClick"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- Academic Panel -->
                    <Grid x:Name="AcademicPanel" Grid.Row="0" Visibility="Collapsed">
                        <Border Padding="16" CornerRadius="8" Background="#1B1F2D">
                            <StackPanel>
                                <TextBlock Text="학업 액션 설정" FontSize="18" FontWeight="Bold"/>
                                <TextBlock Text="수업/튜터링/과제 옵션을 선택하고 주간 계획을 관리합니다." FontSize="12" Foreground="#9FA9C4" Margin="0,4,0,12"/>
                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="지식" FontWeight="Bold"/>
                                        <TextBlock x:Name="AcademicKnowledgeText" FontSize="14"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="집중" FontWeight="Bold"/>
                                        <TextBlock x:Name="AcademicFocusText" FontSize="14"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="평균 내신 등급" FontWeight="Bold"/>
                                        <TextBlock x:Name="AcademicGradeText" FontSize="14"/>
                                    </StackPanel>
                                </Grid>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <TextBlock Text="장학 점수" FontWeight="Bold" Width="120"/>
                                    <TextBlock x:Name="AcademicScholarshipText"/>
                                    <TextBlock Text="  /  경고 점수" Margin="12,0,0,0"/>
                                    <TextBlock x:Name="AcademicWarningText"/>
                                </StackPanel>

                                <StackPanel Margin="0,8,0,0">
                                    <TextBlock Text="수업 옵션" FontWeight="Bold"/>
                                    <ComboBox x:Name="AcademicLectureCombo" Width="320" DisplayMemberPath="Title" SelectionChanged="AcademicLectureCombo_OnSelectionChanged"/>
                                    <TextBlock x:Name="AcademicLectureDescription" FontSize="11" Foreground="#BFC6DD" Margin="0,2,0,0"/>
                                </StackPanel>
                                <StackPanel Margin="0,12,0,0">
                                    <TextBlock Text="튜터링 옵션" FontWeight="Bold"/>
                                    <ComboBox x:Name="AcademicSupportCombo" Width="320" DisplayMemberPath="Title" SelectionChanged="AcademicSupportCombo_OnSelectionChanged"/>
                                    <TextBlock x:Name="AcademicSupportDescription" FontSize="11" Foreground="#BFC6DD" Margin="0,2,0,0"/>
                                </StackPanel>
                                <StackPanel Margin="0,12,0,0">
                                    <TextBlock Text="과제/추가 학습" FontWeight="Bold"/>
                                    <ComboBox x:Name="AcademicStudyCombo" Width="320" DisplayMemberPath="Title" SelectionChanged="AcademicStudyCombo_OnSelectionChanged"/>
                                    <TextBlock x:Name="AcademicStudyDescription" FontSize="11" Foreground="#BFC6DD" Margin="0,2,0,0"/>
                                </StackPanel>

                                <TextBlock Text="학업 로그" FontSize="14" FontWeight="Bold" Margin="0,16,0,4"/>
                                <ListBox x:Name="AcademicLogList" Height="120" Background="#1B1F2D" BorderThickness="1" BorderBrush="#2A2F42">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding}" Foreground="#FFFFFF" TextWrapping="Wrap"/>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </StackPanel>
                        </Border>
                    </Grid>

                     <!-- Schedule Panel -->
                     <Grid x:Name="SchedulePanel" Grid.Row="0" Visibility="Collapsed">
                         <Border Padding="16" CornerRadius="8" Background="#1B1F2D">
                             <StackPanel>
                                 <TextBlock Text="1학년 일정" FontSize="18" FontWeight="Bold"/>
                                <TabControl Margin="0,8,0,0">
                                    <TabItem Header="전체 목록">
                                        <ListView x:Name="ScheduleList" Margin="0,8,0,0">
                                            <ListView.View>
                                                <GridView>
                                                    <GridViewColumn Header="날짜" DisplayMemberBinding="{Binding DateLabel}" Width="140"/>
                                                    <GridViewColumn Header="카테고리" DisplayMemberBinding="{Binding Category}" Width="100"/>
                                                    <GridViewColumn Header="이벤트" DisplayMemberBinding="{Binding Title}" Width="220"/>
                                                    <GridViewColumn Header="설명" DisplayMemberBinding="{Binding Description}" Width="380"/>
                                                </GridView>
                                            </ListView.View>
                                        </ListView>
                                    </TabItem>
                                    <TabItem Header="월별 보기">
                                        <StackPanel>
                                            <ComboBox x:Name="CalendarMonthCombo" Width="200" DisplayMemberPath="Name" Margin="0,0,0,8" SelectionChanged="CalendarMonthCombo_OnSelectionChanged"/>
                                            <ItemsControl x:Name="CalendarDayGrid">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <UniformGrid Columns="7" Rows="6"/>
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border BorderBrush="#2E3448" BorderThickness="1" Padding="6" MinHeight="80">
                                                            <StackPanel>
                                                                <TextBlock Text="{Binding DayText}" FontWeight="Bold"/>
                                                                <ItemsControl ItemsSource="{Binding Events}">
                                                                    <ItemsControl.ItemTemplate>
                                                                        <DataTemplate>
                                                                            <TextBlock FontSize="10" TextWrapping="Wrap">
                                                                                <Run Text=">"/>
                                                                                <Run Text="{Binding Mode=OneWay}"/>
                                                                            </TextBlock>
                                                                        </DataTemplate>
                                                                    </ItemsControl.ItemTemplate>
                                                                </ItemsControl>
                                                            </StackPanel>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </TabItem>
                                 </TabControl>
                             </StackPanel>
                         </Border>
                     </Grid>

                    <!-- Season Panel -->
                    <Grid x:Name="SeasonPanel" Grid.Row="0" Visibility="Collapsed">
                        <Border Padding="16" CornerRadius="8" Background="#1B1F2D">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <StackPanel Grid.Row="0" Margin="0,0,0,12">
                                    <TextBlock Text="리그 · 대회 기록" FontSize="18" FontWeight="Bold"/>
                                    <TextBlock Text="팀 순위표, 대진표, 시즌 스탯을 확인합니다." FontSize="12" Foreground="#9FA9C4" Margin="0,4,0,0"/>
                                </StackPanel>
                                <TabControl Grid.Row="1" Background="#1B1F2D" BorderThickness="0">
                                    <TabItem Header="리그 테이블">
                                        <ListView x:Name="LeagueTableList" Background="#1B1F2D" BorderThickness="0" Margin="0,8,0,0">
                                            <ListView.ItemContainerStyle>
                                                <Style TargetType="ListViewItem">
                                                    <Setter Property="Background" Value="Transparent"/>
                                                    <Setter Property="Foreground" Value="#E6EAF5"/>
                                                    <Setter Property="Padding" Value="2"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsPlayerTeam}" Value="True">
                                                            <Setter Property="Background" Value="#2B3A5B"/>
                                                            <Setter Property="Foreground" Value="#FFFFFF"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </ListView.ItemContainerStyle>
                                            <ListView.View>
                                                <GridView>
                                                    <GridViewColumn Header="팀" DisplayMemberBinding="{Binding TeamName}" Width="200"/>
                                                    <GridViewColumn Header="W" DisplayMemberBinding="{Binding Wins}" Width="40"/>
                                                    <GridViewColumn Header="L" DisplayMemberBinding="{Binding Losses}" Width="40"/>
                                                    <GridViewColumn Header="승률" DisplayMemberBinding="{Binding WinRateText}" Width="70"/>
                                                    <GridViewColumn Header="득점" DisplayMemberBinding="{Binding RunsFor}" Width="60"/>
                                                    <GridViewColumn Header="실점" DisplayMemberBinding="{Binding RunsAgainst}" Width="60"/>
                                                    <GridViewColumn Header="득실" DisplayMemberBinding="{Binding RunDiff}" Width="60"/>
                                                </GridView>
                                            </ListView.View>
                                        </ListView>
                                    </TabItem>
                                    <TabItem Header="대진표">
                                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                                            <ItemsControl x:Name="TournamentRoundList" Margin="0,8,0,0">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <StackPanel Margin="0,0,0,12">
                                                            <TextBlock Text="{Binding Label}" FontWeight="Bold" Margin="0,0,0,6"/>
                                                            <ItemsControl ItemsSource="{Binding Matches}">
                                                                <ItemsControl.ItemTemplate>
                                                                    <DataTemplate>
                                                                        <Border CornerRadius="6" Padding="10" Margin="0,0,0,6">
                                                                            <Border.Style>
                                                                                <Style TargetType="Border">
                                                                                    <Setter Property="Background" Value="#1E2434"/>
                                                                                    <Setter Property="BorderBrush" Value="#2A3247"/>
                                                                                    <Setter Property="BorderThickness" Value="1"/>
                                                                                    <Style.Triggers>
                                                                                        <DataTrigger Binding="{Binding IsPlayerMatch}" Value="True">
                                                                                            <Setter Property="Background" Value="#233250"/>
                                                                                            <Setter Property="BorderBrush" Value="#5ED6B8"/>
                                                                                        </DataTrigger>
                                                                                    </Style.Triggers>
                                                                                </Style>
                                                                            </Border.Style>
                                                                            <Grid>
                                                                                <Grid.ColumnDefinitions>
                                                                                    <ColumnDefinition Width="*"/>
                                                                                    <ColumnDefinition Width="Auto"/>
                                                                                    <ColumnDefinition Width="*"/>
                                                                                    <ColumnDefinition Width="Auto"/>
                                                                                </Grid.ColumnDefinitions>
                                                                                <TextBlock Text="{Binding HomeTeam}" FontWeight="Bold"/>
                                                                                <TextBlock Grid.Column="1" Text="vs" Margin="10,0"/>
                                                                                <TextBlock Grid.Column="2" Text="{Binding AwayTeam}" FontWeight="Bold"/>
                                                                                <TextBlock Grid.Column="3" Text="{Binding Status}" Foreground="#9FA9C4" Margin="12,0,0,0"/>
                                                                            </Grid>
                                                                        </Border>
                                                                    </DataTemplate>
                                                                </ItemsControl.ItemTemplate>
                                                            </ItemsControl>
                                                        </StackPanel>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </ScrollViewer>
                                    </TabItem>
                                    <TabItem Header="시즌 통계">
                                        <StackPanel Margin="0,8,0,0">
                                            <TextBlock Text="투수 시즌 기록" FontWeight="Bold"/>
                                            <TextBlock x:Name="SeasonPitchingStatsText" Margin="0,6,0,12" Foreground="#E6EAF5"/>
                                            <TextBlock Text="드래프트 프리뷰" FontWeight="Bold"/>
                                            <TextBlock x:Name="SeasonDraftSummaryText" Margin="0,6,0,12" Foreground="#E6EAF5"/>
                                            <TextBlock Text="경기 기록" FontWeight="Bold" Margin="0,0,0,6"/>
                                            <ListView x:Name="SeasonMatchHistoryList" Background="#1B1F2D" BorderThickness="0" Height="320">
                                                <ListView.View>
                                                    <GridView>
                                                        <GridViewColumn Header="Day" DisplayMemberBinding="{Binding Day}" Width="50"/>
                                                        <GridViewColumn Header="종류" DisplayMemberBinding="{Binding Kind}" Width="90"/>
                                                        <GridViewColumn Header="스테이지" DisplayMemberBinding="{Binding Stage}" Width="90"/>
                                                        <GridViewColumn Header="상대" DisplayMemberBinding="{Binding Opponent}" Width="140"/>
                                                        <GridViewColumn Header="홈/원정" DisplayMemberBinding="{Binding HomeAway}" Width="70"/>
                                                        <GridViewColumn Header="라이벌" DisplayMemberBinding="{Binding Rivalry}" Width="70"/>
                                                        <GridViewColumn Header="스코어" DisplayMemberBinding="{Binding Score}" Width="90"/>
                                                    </GridView>
                                                </ListView.View>
                                            </ListView>
                                        </StackPanel>
                                    </TabItem>
                                </TabControl>
                            </Grid>
                        </Border>
                    </Grid>

                    <!-- Records Panel -->
                    <Grid x:Name="RecordsPanel" Grid.Row="0" Visibility="Collapsed">
                        <Border Padding="16" CornerRadius="8" Background="#1B1F2D">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <StackPanel Grid.Row="0" Margin="0,0,0,12">
                                    <TextBlock Text="기록 · 로그 아카이브" FontSize="18" FontWeight="Bold"/>
                                    <TextBlock Text="하루 진행 로그와 이벤트를 날짜별로 정리해서 확인합니다." FontSize="12" Foreground="#9FA9C4" Margin="0,4,0,0"/>
                                </StackPanel>
                                <ListBox x:Name="LogBlockList"
                                         Grid.Row="1"
                                         Background="#1B1F2D"
                                         BorderThickness="0"
                                         ScrollViewer.VerticalScrollBarVisibility="Auto">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Expander Header="{Binding Title}"
                                                      IsExpanded="True"
                                                      Background="#23293C"
                                                      Foreground="#F5F5F5"
                                                      Margin="0,0,0,8">
                                                <ItemsControl ItemsSource="{Binding Entries}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Border Background="#1E2434" CornerRadius="4" Padding="6" Margin="0,2,0,2">
                                                                <TextBlock Text="{Binding}" TextWrapping="Wrap" Foreground="#FFFFFF"/>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
