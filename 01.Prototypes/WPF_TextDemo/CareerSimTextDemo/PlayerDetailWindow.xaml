<Window x:Class="CareerSimTextDemo.PlayerDetailWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="선수 능력치" Height="620" Width="920" Background="#131722" Foreground="#F5F5F5"
        ResizeMode="NoResize">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <StackPanel>
            <TextBlock Text="{Binding Header}" FontSize="24" FontWeight="Bold"/>
            <TextBlock Text="{Binding MetaLine}" FontSize="13" Margin="0,4,0,0"/>
            <TextBlock Text="{Binding Tags}" FontSize="12" Foreground="#F0C674" Margin="0,2,0,0"/>
        </StackPanel>
        <Grid Grid.Row="1" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <StackPanel Margin="0,0,10,0">
                <Border Background="#1F2434" CornerRadius="8" Padding="10" Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock Text="신체" FontWeight="Bold"/>
                        <ListView ItemsSource="{Binding PhysicalStats}" Margin="0,6,0,0" Background="#1F2434" BorderThickness="0" Foreground="#F5F5F5">
                            <ListView.View>
                                <GridView>
                                    <GridViewColumn Header="능력" DisplayMemberBinding="{Binding Label}" Width="200"/>
                                    <GridViewColumn Header="값" DisplayMemberBinding="{Binding Value}" Width="60"/>
                                </GridView>
                            </ListView.View>
                        </ListView>
                    </StackPanel>
                </Border>
                <Border Background="#1F2434" CornerRadius="8" Padding="10" Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock Text="투구" FontWeight="Bold"/>
                        <ListView ItemsSource="{Binding PitchingStats}" Margin="0,6,0,0" Background="#1F2434" BorderThickness="0" Foreground="#F5F5F5">
                            <ListView.View>
                                <GridView>
                                    <GridViewColumn Header="능력" DisplayMemberBinding="{Binding Label}" Width="200"/>
                                    <GridViewColumn Header="값" DisplayMemberBinding="{Binding Value}" Width="60"/>
                                </GridView>
                            </ListView.View>
                        </ListView>
                    </StackPanel>
                </Border>
                <Border Background="#1F2434" CornerRadius="8" Padding="10">
                    <StackPanel>
                        <TextBlock Text="타격" FontWeight="Bold"/>
                        <ListView ItemsSource="{Binding BattingStats}" Margin="0,6,0,0" Background="#1F2434" BorderThickness="0" Foreground="#F5F5F5">
                            <ListView.View>
                                <GridView>
                                    <GridViewColumn Header="능력" DisplayMemberBinding="{Binding Label}" Width="200"/>
                                    <GridViewColumn Header="값" DisplayMemberBinding="{Binding Value}" Width="60"/>
                                </GridView>
                            </ListView.View>
                        </ListView>
                    </StackPanel>
                </Border>
            </StackPanel>
            <StackPanel Grid.Column="1" Margin="10,0,0,0">
                <Border Background="#1F2434" CornerRadius="8" Padding="10" Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock Text="멘탈" FontWeight="Bold"/>
                        <ListView ItemsSource="{Binding MentalStats}" Margin="0,6,0,0" Background="#1F2434" BorderThickness="0" Foreground="#F5F5F5">
                            <ListView.View>
                                <GridView>
                                    <GridViewColumn Header="능력" DisplayMemberBinding="{Binding Label}" Width="200"/>
                                    <GridViewColumn Header="값" DisplayMemberBinding="{Binding Value}" Width="60"/>
                                </GridView>
                            </ListView.View>
                        </ListView>
                    </StackPanel>
                </Border>
                <Border Background="#1F2434" CornerRadius="8" Padding="10" Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock Text="히든" FontWeight="Bold"/>
                        <ListView ItemsSource="{Binding HiddenStats}" Margin="0,6,0,0" Background="#1F2434" BorderThickness="0" Foreground="#F5F5F5">
                            <ListView.View>
                                <GridView>
                                    <GridViewColumn Header="능력" DisplayMemberBinding="{Binding Label}" Width="200"/>
                                    <GridViewColumn Header="값" DisplayMemberBinding="{Binding Value}" Width="60"/>
                                </GridView>
                            </ListView.View>
                        </ListView>
                    </StackPanel>
                </Border>
                <Border Background="#1F2434" CornerRadius="8" Padding="10">
                    <StackPanel>
                        <TextBlock Text="비공개" FontWeight="Bold"/>
                        <ListView ItemsSource="{Binding PersonalityStats}" Margin="0,6,0,0" Background="#1F2434" BorderThickness="0" Foreground="#F5F5F5">
                            <ListView.View>
                                <GridView>
                                    <GridViewColumn Header="능력" DisplayMemberBinding="{Binding Label}" Width="200"/>
                                    <GridViewColumn Header="값" DisplayMemberBinding="{Binding Value}" Width="60"/>
                                </GridView>
                            </ListView.View>
                        </ListView>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>
    </Grid>
</Window>

